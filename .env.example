# Spotify App credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback/

# Google Gemini API key (https://aistudio.google.com/app/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# Birthday person's name (used in playlist titles and cover images)
BIRTHDAY_NAME=Sarah

# Reference playlist URL (optional — sets the musical taste baseline)
REFERENCE_PLAYLIST_URL=https://open.spotify.com/playlist/your_playlist_id
